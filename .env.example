# Database
DATABASE_URL=postgresql://user:password@localhost:5432/resume_matcher
SQL_ECHO=false

# Environment
ENVIRONMENT=development
PORT=8000

# JWT
JWT_SECRET=your-secret-key-change-this
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760  # 10MB

# CORS
CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000"]

# --- Email (optional) -- powers forgot-password reset emails ---
# For Gmail: use an App Password (myaccount.google.com/apppasswords), not
# your real account password -- Gmail rejects plain passwords for SMTP.
# Left blank, forgot-password endpoints still respond normally, they just
# log what would've been sent instead of actually emailing it.
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Where the reset-password link in that email should point -- must match
# wherever the frontend is actually reachable from your browser.
FRONTEND_URL=http://localhost:5173

# --- Automatic job sync (optional) ---
# Runs data/sync_jobs.py on a recurring schedule inside the backend
# container. Set to false if you'd rather trigger syncs yourself.
ENABLE_JOB_SYNC_SCHEDULER=true
JOB_SYNC_INTERVAL_HOURS=24

# --- Google Sign-In (optional) ---
# console.cloud.google.com -> create/select a project -> APIs & Services ->
# Credentials -> Create Credentials -> OAuth client ID -> Web application.
# Add Authorized JavaScript origins: http://localhost:5173 (and your real
# domain once deployed). No client secret needed -- this app only verifies
# the ID token Google's own Sign in With Google button returns; it never
# does the server-side code exchange that would need one. Leave blank to
# keep the Google button hidden.
GOOGLE_CLIENT_ID=

# --- Adzuna job source (optional) ---
# developer.adzuna.com/signup -- free, gives you both of these immediately.
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# --- Reed job source (optional, UK jobs) ---
# reed.co.uk/developers -- register for a free API key.
REED_API_KEY=

# --- Jooble job source (optional) ---
# jooble.org/api/about -- register for a free API key.
JOOBLE_API_KEY=
